<!DOCTYPE html>
<html lang="en">
<head>
    <%- include("./partials/head") %>
    <link rel="stylesheet" href="/css/styles.css">
</head>
<body class="d-flex flex-column align-items-center justify-content-center" style="min-height: 100vh; padding: 2rem 0;">
    
    <% if (toast && toast.message) { %>
        <%- include("./partials/toast") %>
    <% } %>
    
    <div class="container d-flex justify-content-center align-items-center flex-grow-1">
        <div class="modern-card animate-fade-up w-100 p-4 p-md-5" style="max-width: 900px; border-radius: var(--radius-lg);">
            <div class="text-center mb-5">
                <a href="/" class="text-decoration-none d-inline-block mb-3">
                    <h3 class="fw-bold text-primary"><i class="fas fa-layer-group me-2"></i>BlogSpace</h3>
                </a>
                <h2 class="display-6 fw-bold text-dark">Welcome Back</h2>
                <p class="text-muted">Don't have an account? <a href="/user/signup" class="text-primary text-decoration-none fw-medium">Sign up</a></p>
            </div>
            
            <div class="row gy-4 justify-content-center align-items-center">
                <div class="col-12 col-lg-5">
                    <form action="/user/signin" method="POST">
                        <div class="form-floating mb-4">
                            <input type="email" class="form-control" name="email" id="email" placeholder="name@example.com" required>
                            <label for="email" class="text-muted">Email address</label>
                        </div>
                        <div class="form-floating mb-4">
                            <input type="password" class="form-control" name="password" id="password" placeholder="Password" required>
                            <label for="password" class="text-muted">Password</label>
                        </div>
                        <div class="d-flex justify-content-between mb-4">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" value="" id="rememberMe">
                                <label class="form-check-label text-muted" for="rememberMe">Remember me</label>
                            </div>
                            <a href="/user/check-mail" class="text-primary text-decoration-none fw-medium">Forgot password?</a>
                        </div>
                        <button class="btn btn-primary-custom w-100 py-2 fs-5" type="submit">Sign in</button>
                    </form>
                </div>
                
                <div class="col-12 col-lg-2 d-flex flex-row flex-lg-column justify-content-center align-items-center my-4 my-lg-0">
                    <div style="height: 1px; width: 100%; background: var(--border-color);" class="d-lg-none"></div>
                    <div style="width: 1px; height: 100px; background: var(--border-color);" class="d-none d-lg-block"></div>
                    <span class="text-muted bg-white px-3 py-1 position-relative" style="z-index: 1;">OR</span>
                    <div style="height: 1px; width: 100%; background: var(--border-color);" class="d-lg-none"></div>
                    <div style="width: 1px; height: 100px; background: var(--border-color);" class="d-none d-lg-block"></div>
                </div>
                
                <div class="col-12 col-lg-5 text-center">
                    <a href="/auth/google" class="btn btn-outline-custom w-100 py-3 d-flex align-items-center justify-content-center gap-3">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" class="bi bi-google text-danger" viewBox="0 0 16 16">
                            <path d="M15.545 6.558a9.42 9.42 0 0 1 .139 1.626c0 2.434-.87 4.492-2.384 5.885h.002C11.978 15.292 10.158 16 8 16A8 8 0 1 1 8 0a7.689 7.689 0 0 1 5.352 2.082l-2.284 2.284A4.347 4.347 0 0 0 8 3.166c-2.087 0-3.86 1.408-4.492 3.304a4.792 4.792 0 0 0 0 3.063h.003c.635 1.893 2.405 3.301 4.492 3.301 1.078 0 2.004-.276 2.722-.764h-.003a3.702 3.702 0 0 0 1.599-2.431H8v-3.08h7.545z" />
                        </svg>
                        <span class="fw-semibold">Continue with Google</span>
                    </a>
                </div>
            </div>
        </div>
    </div>
    
    <%- include("./partials/script") %>
    <%- include("./partials/toastScript") %>
</body>
</html>
