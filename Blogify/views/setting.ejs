<!DOCTYPE html>
<html lang="en">
<head>
  <%- include("./partials/head") %>
  <script src="https://kit.fontawesome.com/a076d05399.js" crossorigin="anonymous"></script>
  <link rel="stylesheet" href="/css/styles.css">
  <style>
    /* Profile Image Overlay for Edit */
    .profile-picture-container {
      position: relative;
      display: inline-block;
      cursor: pointer;
    }
    .profile-picture-container img {
      width: 140px;
      height: 140px;
      object-fit: cover;
      transition: var(--transition-normal);
      border: 4px solid white;
    }
    .edit-overlay {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: rgba(0,0,0,0.5);
      color: white;
      border-radius: 50%;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      opacity: 0;
      transition: var(--transition-normal);
    }
    .profile-picture-container:hover .edit-overlay {
      opacity: 1;
    }
    
    /* Modern Delete Button */
    .delete-btn-overlay {
      position: absolute;
      top: 15px;
      right: 15px;
      background: rgba(255, 255, 255, 0.9);
      border: none;
      color: #ef4444;
      width: 35px;
      height: 35px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow: var(--shadow-sm);
      transition: var(--transition-fast);
      z-index: 10;
    }
    .delete-btn-overlay:hover {
      background: #ef4444;
      color: white;
      transform: scale(1.1);
    }
  </style>
</head>
<body class="d-flex flex-column min-vh-100" onload="hideLoadingSpinner()">
  <%- include("./partials/spinner") %>
  <%- include("./partials/nav") %>
  
  <% if (toast && toast.message) { %>
    <%- include("./partials/toast") %>
  <% } %>

  <main class="flex-grow-1 container py-4 animate-fade-up">
    
    <!-- User Profile Section -->
    <div class="glass-panel p-4 p-md-5 mb-5 text-center text-md-start delay-100">
      <div class="row align-items-center">
        <div class="col-md-3 text-center mb-4 mb-md-0">
          <div class="profile-picture-container shadow-sm rounded-circle" id="edit-icon">
            <img src="<%= profileImage %>" alt="Profile Picture" class="rounded-circle">
            <div class="edit-overlay">
              <i class="fas fa-camera fs-3 mb-1"></i>
              <span style="font-size: 0.8rem; font-weight: 600;">Update</span>
            </div>
          </div>
          <form id="uploadForm" action="/user/upload-profile-image" method="POST" enctype="multipart/form-data">
            <input type="file" name="profileImage" id="profileImageInput" accept="image/*" style="display: none;">
          </form>
        </div>
        
        <div class="col-md-9">
          <h2 class="display-6 fw-bold text-dark mb-2"><%= user.name %></h2>
          <div class="d-flex flex-column flex-md-row gap-3 gap-md-5 text-muted fw-medium mt-3">
            <div><i class="fas fa-envelope text-primary me-2"></i> <%= user.email %></div>
            <div><i class="fas fa-file-alt text-primary me-2"></i> <%= blogs.length %> Blogs Created</div>
          </div>
          <div class="mt-4">
              <a href="/user/change-password" class="btn btn-outline-custom btn-sm"><i class="fas fa-key me-2"></i>Change Password</a>
          </div>
        </div>
      </div>
    </div>

    <!-- Blogs Section -->
    <div class="mb-5">
      <div class="d-flex align-items-center justify-content-between mb-4">
        <h3 class="fw-bold m-0"><i class="fas fa-book-open text-primary me-2"></i>Your Stories</h3>
        <a href="/blog/addBlog" class="btn btn-primary-custom btn-sm"><i class="fas fa-plus me-1"></i> New</a>
      </div>

      <% if (blogs.length === 0) { %>
        <div class="text-center py-5 glass-panel">
          <h5 class="text-muted">You haven't written any blogs yet.</h5>
          <a href="/blog/addBlog" class="btn btn-outline-custom mt-3">Start Writing</a>
        </div>
      <% } else { %>
        <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 g-4">
          <% blogs.forEach((blog, index) => { %>
            <% const delay = (index % 5) * 100 + 200; %>
            <div class="col">
              <div class="modern-card h-100 position-relative animate-fade-up delay-<%= delay %>">
                
                <!-- Delete Form overlay -->
                <form action="/blog/delete/<%= blog._id %>?_method=DELETE" method="POST" class="m-0">
                  <button type="submit" class="delete-btn-overlay" title="Delete Blog" onclick="return confirm('Are you sure you want to delete this blog?');">
                    <i class="fas fa-trash"></i>
                  </button>
                </form>
                
                <div class="card-img-container">
                   <span class="category-badge"><%= blog.category %></span>
                   <img src="<%= blog.coverImage %>" class="card-img-top" alt="Blog Image">
                </div>
                <div class="card-body p-4 d-flex flex-column">
                  
                  <div class="blog-meta mt-1">
                     <div class="d-flex align-items-center">
                       <img src="<%= user.profileImage %>" class="meta-avatar me-2" alt="Author">
                       <span class="fw-semibold text-dark" style="font-size: 0.85rem;"><%= user.name %></span>
                     </div>
                     <span class="text-muted" style="font-size: 0.75rem;"><i class="far fa-calendar-alt me-1"></i> <%= new Date(blog.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></span>
                  </div>

                  <h5 class="card-title fw-bold text-dark mb-3"><%= blog.title %></h5>
                  <p class="card-text text-muted mb-4 flex-grow-1" style="font-size: 0.95rem;">
                    <%= blog.body.replace(/<[^>]*>/g, '').length > 100 ? blog.body.replace(/<[^>]*>/g, '').substring(0, 100) + '...' : blog.body.replace(/<[^>]*>/g, '') %>
                  </p>
                  <a href="/blog/<%= blog._id %>" class="btn btn-outline-custom mt-auto w-100 text-center">Read Article</a>
                </div>
              </div>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>
  </main>
  
  <%- include("./partials/footer") %>
  
  <script>
    const profileImageInput = document.getElementById('profileImageInput');
    const uploadForm = document.getElementById('uploadForm');
    const editIcon = document.getElementById('edit-icon');

    editIcon.addEventListener('click', () => {
      profileImageInput.click();
    });

    profileImageInput.addEventListener('change', () => {
      if (profileImageInput.files.length > 0) {
        uploadForm.submit();
      }
    });
  </script>
  
  <%- include("./partials/script") %>
  <%- include("./partials/toastScript") %>
</body>
</html>
