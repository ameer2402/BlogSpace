<!DOCTYPE html>
<html lang="en">
<head>
    
    <title>Feedback</title>
    <%- include("./partials/head") %>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />
    <link rel="stylesheet" href="/css/footer.css">

</head>
<body onload="hideLoadingSpinner()">
    <%- include("./partials/nav") %>
    <!-- Include the loading spinner -->
    <%- include("./partials/spinner") %>
    
    <%- include("./feedback") %>
    <%- include("./partials/footer") %>
    <%- include("./partials/script") %>
    <script>
        // Function to handle emoji selection
        function setRating(value, selectedEmoji) {
            const ratingInput = document.getElementById("ratingInput");
            if (ratingInput.value == value) {
                ratingInput.value = "";
                selectedEmoji.classList.remove('selected');
            } else {
                ratingInput.value = value;
                const emojis = document.querySelectorAll('.emoji-icon');
                emojis.forEach(emoji => emoji.classList.remove('selected'));
                selectedEmoji.classList.add('selected');
            }
        }
    
        function showSubmitSpinner(event) {
    event.preventDefault(); // Prevent immediate form submission
    const submitButton = document.getElementById("submitButton");
    const spinner = document.getElementById("submitSpinner");
    const buttonText = document.getElementById("buttonText");

    // Update button text to "Submitting..." and show the spinner
    buttonText.textContent = "Submitting...";
    spinner.style.display = "inline-block";

    // Disable the submit button to prevent multiple submissions
    submitButton.disabled = true;

    // Delay form submission to allow the spinner to display briefly
    setTimeout(() => {
        document.getElementById("feedbackForm").submit(); // Submit the form after 1 second
    }, 1000);
}
    </script>
</body>



</html>