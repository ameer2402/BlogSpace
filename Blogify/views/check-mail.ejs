<!DOCTYPE html>
<html lang="en">
<head>
    <title>Email Verification</title>
    <%- include("./partials/head") %>
    <link rel="stylesheet" href="/css/footer.css">
    <link rel="stylesheet" href="/css/spinner.css">

</head>
<body>
    <%- include("./partials/nav") %>
    <!-- Spinner Overlay (Initially Hidden) -->
<div id="spinnerOverlay" class="spinner-overlay" style="display: none;">
    <div class="loader"></div>
</div>


    <!-- Main Container -->
    <div class="container d-flex justify-content-center align-items-center animate-fade-up" style="min-height: 80vh;">
        <div class="modern-card p-4 p-md-5 w-100" style="max-width: 500px;">
            <div class="text-center mb-4">
                <div class="mb-3">
                    <i class="fas fa-envelope-open-text text-primary" style="font-size: 3.5rem;"></i>
                </div>
                <h2 class="fw-bold text-dark mb-2">Verify Your Email</h2>
                <p class="text-muted">Enter the email associated with your account to reset your password.</p>
            </div>
            
            <form id="emailForm" method="POST" action="/check-mail">
                <div class="form-floating mb-4 position-relative">
                    <input type="email" class="form-control" id="email" name="email" placeholder="Enter your email" required>
                    <label for="email" class="text-muted">Email address</label>
                    <div id="emailFeedback" class="invalid-feedback text-center mt-2 fw-semibold">
                        User does not exist.
                    </div>
                </div>
                <button type="submit" class="btn btn-primary-custom w-100 py-3 fs-5">Check Email <i class="fas fa-arrow-right ms-2"></i></button>
            </form>
        </div>
    </div>

    <%- include("./partials/footer") %>
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
    <%- include("./partials/script") %>
    <script>
        document.getElementById("emailForm").addEventListener("submit", async function(event) {
            event.preventDefault();
            const email = document.getElementById("email").value;
                    // Get the spinner overlay
        const spinnerOverlay = document.getElementById("spinnerOverlay");
          // Show the spinner overlay
          spinnerOverlay.style.display = "flex"; // Show the overlay with the loader

            try {
                const response = await axios.post('/user/check-mail', { email });
                const result = response.data;

                const emailFeedback = document.getElementById("emailFeedback");
                if (result.exists) {
                    window.location.href = "/user/verify-otp";
                    
                } 
                else{
                    emailFeedback.style.display = "block";
                    document.getElementById("email").classList.add("is-invalid");
                }
            } catch (error) {
                console.error("Error checking email:", error);
            }
            finally {
            // Hide the spinner overlay
            spinnerOverlay.style.display = "none"; // Hide the spinner once the process is complete
        }  

        });
    </script>
</body>
</html>
