<footer class="mt-auto border-top" style="background-color: var(--surface-solid); position: relative; z-index: 10;">
    <!-- Section: Social media -->
    <section class="d-flex justify-content-center justify-content-lg-between align-items-center p-4 border-bottom" style="background-color: rgba(99, 102, 241, 0.05);">
        <div class="me-5 d-none d-lg-block">
            <span class="text-muted fw-medium">Get connected with us on social networks:</span>
        </div>
        <div class="d-flex align-items-center gap-4">
            <a href="https://www.instagram.com/i_mr_khan.786/" class="text-primary social-icon fs-5">
                <i class="fab fa-instagram"></i>
            </a>
            <a href="https://www.linkedin.com/in/mohammed-ameerkhan-22368626a/" class="text-primary social-icon fs-5">
                <i class="fab fa-linkedin"></i>
            </a>
            <a href="https://github.com/ameer2402" class="text-primary social-icon fs-5">
                <i class="fab fa-github"></i>
            </a>
            <% if (locals.user) { %>
                <!-- Feedback Button for Large Screens -->
                <a href="/user/create-feedback" class="btn btn-primary-custom btn-sm ms-3 d-none d-lg-inline-flex align-items-center">
                    <i class="fas fa-comment-dots me-2"></i> Feedback
                </a>
            <% } %>
        </div>
    </section>

    <!-- Section: Links -->
    <section class="py-5">
        <div class="container text-center text-md-start">
            <div class="row mt-3">
                <!-- About Column -->
                <div class="col-md-4 col-lg-4 col-xl-4 mx-auto mb-4">
                    <h6 class="text-uppercase fw-bold d-flex align-items-center justify-content-center justify-content-md-start mb-4 text-dark">
                        <i class="fas fa-layer-group me-2 text-primary fs-5"></i> BlogSpace
                    </h6>
                    <p class="text-muted" style="line-height: 1.8;">
                        Join our community to read, write, and share stories that inspire and connect. Stay tuned, stay inspired!
                    </p>
                </div>

                <!-- Navigation Links Column -->
                <div class="col-md-3 col-lg-2 col-xl-2 mx-auto mb-4">
                    <h6 class="text-uppercase fw-bold mb-4 text-dark">Navigation</h6>
                    <p><a href="/" class="text-muted text-decoration-none hover-text-primary transition">Home</a></p>
                    <% if (locals.user) { %>
                        <p><a href="/blog/addblog" class="text-muted text-decoration-none hover-text-primary transition">Add Blog</a></p>
                        <p><a href="/user/setting" class="text-muted text-decoration-none hover-text-primary transition">Settings</a></p>
                    <% } %>
                </div>

                <!-- Useful Links Column -->
                <div class="col-md-3 col-lg-2 col-xl-2 mx-auto mb-4">
                    <h6 class="text-uppercase fw-bold mb-4 text-dark">Useful Links</h6>
                    <p><a href="/privacy" class="text-muted text-decoration-none hover-text-primary transition">Privacy Policy</a></p>
                    <p><a href="/terms" class="text-muted text-decoration-none hover-text-primary transition">Terms & Conditions</a></p>
                </div>
            </div>
            <% if (locals.user) { %>
                <div class="text-center mt-3 d-lg-none">
                    <a href="/user/create-feedback" class="btn btn-primary-custom px-4 shadow-sm">
                        <i class="fas fa-comment-dots me-2"></i> Give Feedback
                    </a>
                </div>
            <% } %>
        </div>
    </section>

    <!-- Copyright -->
    <div class="text-center p-4 text-muted border-top" style="background-color: rgba(0,0,0,0.02);">
        &copy; 2024 BlogSpace. All rights reserved.
    </div>
</footer>

<style>
.social-icon {
    transition: transform 0.3s ease, color 0.3s ease;
}
.social-icon:hover {
    transform: translateY(-3px) scale(1.15);
    color: var(--primary-hover) !important;
}
.hover-text-primary {
    transition: all 0.3s ease;
}
.hover-text-primary:hover {
    color: var(--primary-color) !important;
    padding-left: 6px;
}
</style>
