<script
  src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
  integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
  crossorigin="anonymous"
  
></script>
<script src=
"https://ajax.googleapis.com/ajax/libs/jquery/3.5.1/jquery.min.js">
    </script>
    
    <script src=
"https://cdnjs.cloudflare.com/ajax/libs/bootstrap-3-typeahead/4.0.2/bootstrap3-typeahead.min.js">
    </script>

<script>
    // Initializes input with a typeahead
    var $input = $(".typeahead");
    const sourceArray = [
        "Personal",
        "Professional",
        "Travel",
        "Health and Fitness",
        "Tech",
        "Food",
        "Business and Finance",
        "Educational",
        "Fashion",
        "Parenting",
        "Entertainment",
        "Do It Yourself",
        "Photography",
        "Sports",
        "News",
        "Gaming",
        "Art and Design",
        "Book",
    ];

    // Initialize typeahead with the source array
    $input.typeahead({
        source: sourceArray,
        autoSelect: true,
    });

    // Listen for changes in the input field
    $input.on('input', function () {
        var inputVal = $input.val(); // Get input as typed by user
        var lowerCaseInput = inputVal.toLowerCase(); // Convert to lowercase for matching

        // Filter items based on lowercase input
        var matches = sourceArray.filter(item => item.toLowerCase().includes(lowerCaseInput));

        // Update the typeahead source with filtered matches
        $input.data('bs.typeahead').source = matches;
        $input.typeahead('lookup'); // Show the updated matches
    });
</script>

<script>
    // Show spinner
    function showLoadingSpinner() {
      document.getElementById("loadingSpinner").style.display = "flex";
    }
  
    // Hide spinner after ensuring a minimum of 1 second
    function hideLoadingSpinner() {
      setTimeout(() => {
        document.getElementById("loadingSpinner").style.display = "none";
      }, 1000);
    }
  
    // Initial display control
    document.addEventListener("DOMContentLoaded", function () {
      showLoadingSpinner();  // Show immediately on load
      window.addEventListener("load", hideLoadingSpinner);  // Hide when page fully loads
    });
  </script>
  
  <script>
    // AJAX Bookmark Toggler
    function toggleBookmark(button) {
      const blogId = button.getAttribute('data-id');
      if (!blogId) return;

      fetch(`/user/bookmark/${blogId}`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        }
      })
      .then(res => res.json())
      .then(data => {
        const icon = button.querySelector('i');
        if (data.bookmarked) {
          button.classList.add('bookmarked');
          icon.className = 'fas fa-bookmark';
        } else {
          button.classList.remove('bookmarked');
          icon.className = 'far fa-bookmark';
        }
      })
      .catch(err => console.error('Error bookmarking:', err));
    }

    // AJAX Search Autocomplete setup
    document.addEventListener('DOMContentLoaded', () => {
      const setupAutocomplete = (inputId, dropdownId) => {
        const input = document.getElementById(inputId);
        const dropdown = document.getElementById(dropdownId);
        if (!input || !dropdown) return;

        let debounceTimer;

        input.addEventListener('input', () => {
          clearTimeout(debounceTimer);
          const query = input.value.trim();

          if (query.length < 2) {
            dropdown.style.display = 'none';
            dropdown.innerHTML = '';
            return;
          }

          debounceTimer = setTimeout(() => {
            fetch(`/blog/api/search-autocomplete?q=${encodeURIComponent(query)}`)
              .then(res => res.json())
              .then(data => {
                if (data.length === 0) {
                  dropdown.style.display = 'none';
                  dropdown.innerHTML = '';
                  return;
                }

                dropdown.innerHTML = data.map(item => `
                  <a href="/blog/${item._id}" class="autocomplete-item">
                    <div class="d-flex align-items-center justify-content-between">
                      <strong style="font-size: 0.9rem;">${item.title}</strong>
                      <span class="badge bg-light text-primary text-uppercase" style="font-size: 0.6rem;">${item.category}</span>
                    </div>
                  </a>
                `).join('');
                dropdown.style.display = 'block';
              })
              .catch(err => console.error('Autocomplete error:', err));
          }, 250);
        });

        // Hide when clicking outside
        document.addEventListener('click', (e) => {
          if (!input.contains(e.target) && !dropdown.contains(e.target)) {
            dropdown.style.display = 'none';
          }
        });
      };

      setupAutocomplete('navbar-search-desktop', 'autocomplete-results-desktop');
      setupAutocomplete('navbar-search-mobile', 'autocomplete-results-mobile');
    });
  </script>
  
  


  
