<!DOCTYPE html>
<html lang="en">
<head>
  <%- include("./partials/head") %>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />
  <link rel="stylesheet" href="/css/styles.css">
  <link rel="stylesheet" href="/css/spinner.css">
</head>

<body onload="hideLoadingSpinner()">
  <!-- Include the loading spinner -->
  <%- include("./partials/spinner") %>
  
  <%- include("./partials/nav") %>
  
  <% if (toast && toast.message) { %>
    <%- include("./partials/toast") %>
  <% } %>

  <!-- Hero Section -->
  <div class="container-fluid py-5 mb-4 animate-fade-up">
    <div class="container text-center">
      <% if (locals.searchQuery) { %>
        <h1 class="display-4 fw-bold text-dark mb-3">Showing results for: <span class="text-primary"><%= locals.searchQuery %></span></h1>
        <p class="lead text-muted mx-auto" style="max-width: 600px;">Explore the latest insights in this category.</p>
        <a href="/" class="btn btn-outline-custom mt-3"><i class="fas fa-arrow-left me-2"></i>Back to All Blogs</a>
      <% } else { %>
        <h1 class="display-4 fw-bold text-dark mb-3">Discover Inspiring Stories</h1>
        <p class="lead text-muted mx-auto" style="max-width: 600px;">Explore the latest insights, tutorials, and lifestyle posts from our growing community of creators.</p>
      <% } %>
    </div>
  </div>

  <div class="container mb-5">
    <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 g-5 animate-fade-up" style="animation-delay: 0.2s;">
      <% blogs.forEach((blog, index) => { %>
      <% const delay = (index % 5) * 100 + 100; %>
      <div class="col">
        <div class="modern-card h-100 animate-fade-up delay-<%= delay %> position-relative">
          <div class="card-img-container">
             <span class="category-badge"><%= blog.category %></span>
             <img src="<%= blog.coverImage %>" class="card-img-top" alt="Blog Image" />
          </div>
          <div class="card-body p-4 d-flex flex-column">
            
            <div class="blog-meta mt-1">
               <div class="d-flex align-items-center">
                 <img src="<%= blog.createdBy.profileImage %>" class="meta-avatar me-2" alt="Author">
                 <span class="fw-semibold text-dark" style="font-size: 0.85rem;"><%= blog.createdBy.name %></span>
               </div>
               <span class="text-muted" style="font-size: 0.75rem;"><i class="far fa-calendar-alt me-1"></i> <%= new Date(blog.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></span>
            </div>

            <h5 class="card-title text-dark mb-3" style="font-weight: 700; line-height: 1.4;"><%= blog.title %></h5>
            <p class="card-text text-muted mb-4 flex-grow-1" style="font-size: 0.95rem;">
              <%= blog.body.replace(/<[^>]*>/g, '').length > 120 ? blog.body.replace(/<[^>]*>/g, '').substring(0, 120) + '...' : blog.body.replace(/<[^>]*>/g, '') %>
            </p>
            <div class="d-flex align-items-center justify-content-between mt-auto">
              <a href="/blog/<%= blog._id %>" class="btn btn-outline-custom w-100">Read Article <i class="fas fa-arrow-right ms-2 fs-6"></i></a>
            </div>
          </div>
        </div>
      </div>
      <% }) %>
      
      <% if (blogs.length === 0) { %>
        <div class="col-12 text-center py-5 w-100">
            <img src="https://cdni.iconscout.com/illustration/premium/thumb/empty-state-2130362-1800926.png" alt="No blogs" width="300" class="mb-4 opacity-75">
            <h4 class="text-muted">No stories published yet!</h4>
            <p class="text-muted">Be the first to share something amazing.</p>
        </div>
      <% } %>
    </div>
  </div>
  
  <%- include("./partials/footer") %>
  <%- include("./partials/script") %>
  <%- include("./partials/toastScript") %>
</body>
</html>
