<!DOCTYPE html>
<html lang="en">
<head>
    <%- include("./partials/head") %>
    <link rel="stylesheet" href="/css/styles.css">
    <style>
        .blog-content {
            font-size: 1.125rem;
            line-height: 1.8;
            color: #334155;
        }
        .blog-content img {
            max-width: 100%;
            height: auto;
            border-radius: var(--radius-md);
            margin: 1.5rem 0;
        }
        .author-card {
            background: var(--surface-solid);
            border: 1px solid var(--border-color);
            border-radius: var(--radius-pill);
            padding: 0.5rem 1.5rem 0.5rem 0.5rem;
            display: inline-flex;
            align-items: center;
            gap: 1rem;
            transition: var(--transition-normal);
            text-decoration: none;
            color: var(--text-main);
            box-shadow: var(--shadow-sm);
        }
        .author-card:hover {
            transform: translateY(-2px);
            box-shadow: var(--shadow-md);
            border-color: var(--primary-light);
        }
        .comment-bubble {
            background: var(--surface-solid);
            border: 1px solid var(--border-color);
            border-radius: var(--radius-lg);
            padding: 1rem 1.5rem;
            margin-bottom: 1rem;
            box-shadow: var(--shadow-sm);
            transition: var(--transition-fast);
        }
        .comment-bubble:hover {
            border-color: var(--primary-light);
        }
        .blog-header {
            font-size: 2.5rem;
            font-weight: 800;
            line-height: 1.2;
            margin-bottom: 1.5rem;
            color: var(--text-main);
        }
    </style>
</head>
<body class="d-flex flex-column min-vh-100">
    <%- include("./partials/nav") %>
    
    <% if (toast && toast.message) { %>
        <%- include("./partials/toast") %>
    <% } %>

    <main class="flex-grow-1 container mt-4 animate-fade-up">
        <article class="mx-auto" style="max-width: 800px;">
            <header class="text-center mb-4">
                <h1 class="blog-header"><%= blog.title %></h1>
                
                <div class="d-flex justify-content-center mt-4 mb-2">
                    <a href="/blog/user/<%= blog.createdBy._id %>" class="author-card">
                        <img src="<%= blog.createdBy.profileImage %>" alt="Author" class="rounded-circle object-fit-cover" width="45" height="45">
                        <div class="text-start">
                            <span class="d-block fw-bold fs-6"><%= blog.createdBy.name %></span>
                            <span class="d-block text-muted" style="font-size: 0.8rem;">Author</span>
                        </div>
                    </a>
                </div>
            </header>

            <div class="text-center mb-5">
                <img src="<%= blog.coverImage %>" alt="Cover Image" class="img-fluid shadow-sm" style="max-height: 600px; width: auto; object-fit: contain; border-radius: var(--radius-lg);">
            </div>

            <div class="blog-content">
                <%- blog.body %>
            </div>

            <hr class="my-5" style="border-color: var(--border-color);">

            <section class="comments-section mb-5">
                <h3 class="fw-bold mb-4 d-flex align-items-center gap-2">
                    <i class="fas fa-comments text-primary"></i> 
                    <%= comments.length %> Comments
                </h3>

                <% if (locals.user) { %>
                    <div class="mb-5 glass-panel p-4" style="background: rgba(255,255,255,0.5);">
                        <form method="POST" action="/blog/comment/<%= blog._id %>">
                            <div class="form-floating mb-3">
                                <textarea class="form-control" placeholder="Leave a comment here" id="comment" name="content" style="height: 100px; resize: none;" required></textarea>
                                <label for="comment" class="text-muted">Write your thoughts...</label>
                            </div>
                            <button type="submit" class="btn btn-primary-custom px-4">Post Comment <i class="fas fa-paper-plane ms-2"></i></button>
                        </form>
                    </div>
                <% } else { %>
                    <div class="alert alert-light border shadow-sm text-center py-4 mb-5" role="alert">
                        <p class="mb-0 text-muted">Please <a href="/user/signin" class="fw-semibold text-primary text-decoration-none">sign in</a> to leave a comment.</p>
                    </div>
                <% } %>

                <% if (locals.comments.length > 0) { %>
                    <div class="comments-list">
                        <% comments.forEach(comment => { %>
                            <div class="d-flex gap-3 mb-3">
                                <img src="<%= comment.createdBy.profileImage %>" alt="Profile" class="rounded-circle object-fit-cover shadow-sm mt-1" width="40" height="40">
                                <div class="comment-bubble flex-grow-1">
                                    <div class="fw-bold fs-6 text-dark mb-1"><%= comment.createdBy.name %></div>
                                    <div class="text-muted" style="white-space: pre-wrap; font-size: 0.95rem;"><%= comment.content %></div>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                <% } %>
            </section>
        </article>
    </main>
    
    <%- include("./partials/footer") %>
    <%- include("./partials/script") %>
    <%- include("./partials/toastScript") %>
</body>
</html>
