<!DOCTYPE html>
<html lang="en">
<head>
    <%- include("./partials/head") %>
    <link rel="stylesheet" href="/css/styles.css">
    <style>
        .blog-content {
            font-size: 1.125rem;
            line-height: 1.8;
            color: #334155;
        }
        .blog-content img {
            max-width: 100%;
            height: auto;
            border-radius: var(--radius-md);
            margin: 1.5rem 0;
        }
        .author-card {
            background: var(--surface-solid);
            border: 1px solid var(--border-color);
            border-radius: var(--radius-pill);
            padding: 0.5rem 1.5rem 0.5rem 0.5rem;
            display: inline-flex;
            align-items: center;
            gap: 1rem;
            transition: var(--transition-normal);
            text-decoration: none;
            color: var(--text-main);
            box-shadow: var(--shadow-sm);
        }
        .author-card:hover {
            transform: translateY(-2px);
            box-shadow: var(--shadow-md);
            border-color: var(--primary-light);
        }
        .comment-bubble {
            background: var(--surface-solid);
            border: 1px solid var(--border-color);
            border-radius: var(--radius-lg);
            padding: 1rem 1.5rem;
            margin-bottom: 1rem;
            box-shadow: var(--shadow-sm);
            transition: var(--transition-fast);
        }
        .comment-bubble:hover {
            border-color: var(--primary-light);
        }
        .blog-header {
            font-size: 2.5rem;
            font-weight: 800;
            line-height: 1.2;
            margin-bottom: 1.5rem;
            color: var(--text-main);
        }
    </style>
</head>
<body class="d-flex flex-column min-vh-100">
    <div id="scroll-progress"></div>
    <%- include("./partials/nav") %>
    
    <% if (toast && toast.message) { %>
        <%- include("./partials/toast") %>
    <% } %>

    <!-- Floating Social Share Panel -->
    <div class="floating-share-bar">
        <button class="share-icon-btn share-twitter" onclick="sharePost('twitter')" title="Share on X/Twitter">
            <i class="fab fa-twitter"></i>
        </button>
        <button class="share-icon-btn share-linkedin" onclick="sharePost('linkedin')" title="Share on LinkedIn">
            <i class="fab fa-linkedin-in"></i>
        </button>
        <button class="share-icon-btn share-whatsapp" onclick="sharePost('whatsapp')" title="Share on WhatsApp">
            <i class="fab fa-whatsapp"></i>
        </button>
        <button class="share-icon-btn share-link" onclick="sharePost('copy')" title="Copy Link">
            <i class="fas fa-link"></i>
        </button>
    </div>

    <main class="flex-grow-1 container mt-4 animate-fade-up">
        <article class="mx-auto" style="max-width: 800px;">
            <header class="text-center mb-4">
                <h1 class="blog-header"><%= blog.title %></h1>
                
                <div class="d-flex justify-content-center align-items-center flex-wrap gap-3 mt-3 mb-2" style="font-size: 0.9rem;">
                    <a href="/blog/user/<%= blog.createdBy._id %>" class="author-card" style="border-radius: var(--radius-pill); padding: 0.4rem 1.2rem 0.4rem 0.4rem;">
                        <img src="<%= blog.createdBy.profileImage %>" alt="Author" class="rounded-circle object-fit-cover" width="36" height="36">
                        <div class="text-start">
                            <span class="d-block fw-bold fs-6"><%= blog.createdBy.name %></span>
                        </div>
                    </a>
                    
                    <span class="text-muted">•</span>
                    <span class="text-muted" style="font-weight: 500;"><i class="far fa-calendar-alt me-1"></i> <%= new Date(blog.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></span>
                    <span class="text-muted">•</span>
                    <span class="text-muted" style="font-weight: 500;"><i class="fas fa-bolt text-warning me-1"></i> <%= blog.readingTime %> min read</span>
                </div>
            </header>

            <div class="text-center mb-5">
                <img src="<%= blog.coverImage %>" alt="Cover Image" class="img-fluid shadow-sm" style="max-height: 600px; width: auto; object-fit: contain; border-radius: var(--radius-lg);">
            </div>

            <div class="blog-content">
                <%- blog.body %>
            </div>

            <section class="comments-section mb-5">
                <h3 class="fw-bold mb-4 d-flex align-items-center gap-2">
                    <i class="fas fa-comments text-primary"></i> 
                    Comments
                </h3>

                <% if (locals.user) { %>
                    <div class="mb-5 glass-panel p-4" style="background: rgba(255,255,255,0.5);">
                        <form method="POST" action="/blog/comment/<%= blog._id %>">
                            <div class="form-floating mb-3">
                                <textarea class="form-control" placeholder="Leave a comment here" id="comment" name="content" style="height: 100px; resize: none;" required></textarea>
                                <label for="comment" class="text-muted">Write your thoughts...</label>
                            </div>
                            <button type="submit" class="btn btn-primary-custom px-4">Post Comment <i class="fas fa-paper-plane ms-2"></i></button>
                        </form>
                    </div>
                <% } else { %>
                    <div class="alert alert-light border shadow-sm text-center py-4 mb-5" role="alert">
                        <p class="mb-0 text-muted">Please <a href="/user/signin" class="fw-semibold text-primary text-decoration-none">sign in</a> to leave a comment.</p>
                    </div>
                <% } %>

                <% if (locals.comments && locals.comments.length > 0) { %>
                    <div class="comments-list">
                        <% function renderComments(commentList) { %>
                            <% commentList.forEach(comment => { %>
                                <div class="d-flex gap-3 mb-3 flex-column">
                                    <div class="d-flex gap-3">
                                        <img src="<%= comment.createdBy.profileImage %>" alt="Profile" class="rounded-circle object-fit-cover shadow-sm mt-1" width="40" height="40">
                                        <div class="comment-card flex-grow-1">
                                            <div class="fw-bold fs-6 text-dark mb-1"><%= comment.createdBy.name %></div>
                                            <div class="text-muted" style="white-space: pre-wrap; font-size: 0.95rem;"><%= comment.content %></div>
                                            
                                            <% if (locals.user) { %>
                                                <div class="mt-2 text-start">
                                                    <span class="reply-btn" onclick="toggleReplyForm('<%= comment._id %>')">
                                                        <i class="fas fa-reply"></i> Reply
                                                    </span>
                                                </div>
                                                
                                                <!-- Reply Form -->
                                                <div class="reply-form-container" id="reply-form-<%= comment._id %>">
                                                    <form class="mt-2" method="POST" action="/blog/comment/<%= blog._id %>">
                                                        <input type="hidden" name="parentId" value="<%= comment._id %>">
                                                        <div class="mb-2">
                                                            <textarea class="form-control" placeholder="Write a reply..." name="content" rows="2" style="font-size: 0.85rem;" required></textarea>
                                                        </div>
                                                        <button type="submit" class="btn btn-primary-custom btn-sm px-3 py-1" style="font-size: 0.8rem;">Reply</button>
                                                    </form>
                                                </div>
                                            <% } %>
                                        </div>
                                    </div>
                                    
                                    <!-- Nested Replies -->
                                    <% if (comment.replies && comment.replies.length > 0) { %>
                                        <div class="comment-thread">
                                            <% renderComments(comment.replies) %>
                                        </div>
                                    <% } %>
                                </div>
                            <% }) %>
                        <% } %>
                        
                        <% renderComments(comments) %>
                    </div>
                <% } else { %>
                    <div class="text-center py-4 text-muted">
                        <i class="far fa-comment-dots fs-3 mb-2 d-block"></i> No comments yet. Share your thoughts!
                    </div>
                <% } %>
            </section>
        </article>
    </main>
    
    <%- include("./partials/footer") %>
    <%- include("./partials/script") %>
    <%- include("./partials/toastScript") %>

    <script>
        // Scroll progress bar
        window.addEventListener('scroll', () => {
            const docHeight = document.documentElement.scrollHeight - window.innerHeight;
            if (docHeight > 0) {
                const scrolled = (window.scrollY / docHeight) * 100;
                document.getElementById('scroll-progress').style.width = scrolled + '%';
            }
        });

        // Toggle reply form visibility
        function toggleReplyForm(commentId) {
            const form = document.getElementById(`reply-form-${commentId}`);
            if (form) {
                form.style.display = form.style.display === 'block' ? 'none' : 'block';
            }
        }

        // Reactions are currently disabled

        // Social sharing utility
        function sharePost(platform) {
            const url = encodeURIComponent(window.location.href);
            const title = encodeURIComponent("<%= blog.title %>");
            let shareUrl = '';
            
            switch (platform) {
                case 'twitter':
                    shareUrl = `https://twitter.com/intent/tweet?url=${url}&text=${title}`;
                    window.open(shareUrl, '_blank');
                    break;
                case 'linkedin':
                    shareUrl = `https://www.linkedin.com/sharing/share-offsite/?url=${url}`;
                    window.open(shareUrl, '_blank');
                    break;
                case 'whatsapp':
                    shareUrl = `https://api.whatsapp.com/send?text=${title}%20${url}`;
                    window.open(shareUrl, '_blank');
                    break;
                case 'copy':
                    navigator.clipboard.writeText(window.location.href)
                        .then(() => alert("Post link copied to clipboard!"))
                        .catch(err => console.error("Clipboard copy failed:", err));
                    break;
            }
        }
    </script>
</body>
</html>
